{
  "name": "Maps",
  "path": "./Device/Vendor/MSFT/Policy/Config",
  "nodes": [
    {
      "name": "AllowOfflineMapsDownloadOverMeteredConnection",
      "path": "./Device/Vendor/MSFT/Policy/Config/Maps/AllowOfflineMapsDownloadOverMeteredConnection",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Allows the download and update of map data over metered connections. After the policy is applied, you can verify the settings in the user interface in System \u003e Offline Maps.",
      "default": "65535",
      "applicability": {
        "minOsBuild": "10.0.14393",
        "cspVersion": "4.1",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "Disabled. Force disable auto-update over metered connection."
          },
          {
            "value": "1",
            "description": "Enabled. Force enable auto-update over metered connection."
          },
          {
            "value": "65535",
            "description": "Not configured. User's choice."
          }
        ]
      }
    },
    {
      "name": "EnableOfflineMapsAutoUpdate",
      "path": "./Device/Vendor/MSFT/Policy/Config/Maps/EnableOfflineMapsAutoUpdate",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Disables the automatic download and update of map data. After the policy is applied, you can verify the settings in the user interface in System \u003e Offline Maps.",
      "default": "65535",
      "applicability": {
        "minOsBuild": "10.0.14393",
        "cspVersion": "4.1",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "Disabled. Force off auto-update."
          },
          {
            "value": "1",
            "description": "Enabled. Force on auto-update."
          },
          {
            "value": "65535",
            "description": "Not configured. User's choice."
          }
        ]
      }
    }
  ]
}
