{
  "name": "Authentication",
  "path": "./Device/Vendor/MSFT/Policy/Config",
  "nodes": [
    {
      "name": "AllowAadPasswordReset",
      "path": "./Device/Vendor/MSFT/Policy/Config/Authentication/AllowAadPasswordReset",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Specifies whether password reset is enabled for AAD accounts.",
      "default": "0",
      "applicability": {
        "minOsBuild": "10.0.16299",
        "cspVersion": "6.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "Not allowed."
          },
          {
            "value": "1",
            "description": "Allowed."
          }
        ]
      }
    },
    {
      "name": "AllowEAPCertSSO",
      "path": "./Device/Vendor/MSFT/Policy/Config/Authentication/AllowEAPCertSSO",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Allows an EAP cert-based authentication for a single sign on (SSO) to access internal resources.",
      "default": "0",
      "applicability": {
        "minOsBuild": "10.0.10240",
        "cspVersion": "1.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "Not allowed."
          },
          {
            "value": "1",
            "description": "Allowed."
          }
        ]
      }
    },
    {
      "name": "AllowFastReconnect",
      "path": "./Device/Vendor/MSFT/Policy/Config/Authentication/AllowFastReconnect",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Allows EAP Fast Reconnect from being attempted for EAP Method TLS. Most restricted value is 0.",
      "default": "1",
      "applicability": {
        "minOsBuild": "10.0.14393",
        "cspVersion": "4.1",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x62;0x63;0x64;0x65;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x88;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "Not allowed."
          },
          {
            "value": "1",
            "description": "Allowed."
          }
        ]
      }
    },
    {
      "name": "AllowSecondaryAuthenticationDevice",
      "path": "./Device/Vendor/MSFT/Policy/Config/Authentication/AllowSecondaryAuthenticationDevice",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Allows secondary authentication devices to work with Windows. The default for this policy must be on for consumer devices (defined as local or Microsoft account connected device) and off for enterprise devices (such as cloud domain-joined, cloud domain-joined in an on-premises only environment, cloud domain-joined in a hybrid environment, and BYOD). In the next major release of Windows 10, the default for this policy for consumer devices will be changed to off. This will only affect users that have not already set up a secondary authentication device.",
      "default": "0",
      "applicability": {
        "minOsBuild": "10.0.14393",
        "cspVersion": "4.1",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x62;0x63;0x64;0x65;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "Not allowed."
          },
          {
            "value": "1",
            "description": "Allowed."
          }
        ]
      }
    },
    {
      "name": "ConfigureWebSignInAllowedUrls",
      "path": "./Device/Vendor/MSFT/Policy/Config/Authentication/ConfigureWebSignInAllowedUrls",
      "format": "chr",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Specifies a list of URLs that are navigable in Web Sign-in based authentication scenarios.",
      "applicability": {
        "minOsBuild": "10.0.17134.2145",
        "cspVersion": "7.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "None"
      }
    },
    {
      "name": "ConfigureWebcamAccessDomainNames",
      "path": "./Device/Vendor/MSFT/Policy/Config/Authentication/ConfigureWebcamAccessDomainNames",
      "format": "chr",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Specifies a list of domains that are allowed to access the webcam in Web Sign-in based authentication scenarios.",
      "applicability": {
        "minOsBuild": "10.0.22000",
        "cspVersion": "11.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "None"
      }
    },
    {
      "name": "EnableFastFirstSignIn",
      "path": "./Device/Vendor/MSFT/Policy/Config/Authentication/EnableFastFirstSignIn",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Specifies whether new non-admin AAD accounts should auto-connect to pre-created candidate local accounts",
      "default": "0",
      "applicability": {
        "minOsBuild": "10.0.17763",
        "cspVersion": "8.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "The feature defaults to the existing SKU and device capabilities."
          },
          {
            "value": "1",
            "description": "Enabled. Auto-connect new non-admin Azure AD accounts to pre-configured candidate local accounts"
          },
          {
            "value": "2",
            "description": "Disabled. Do not auto-connect new non-admin Azure AD accounts to pre-configured local accounts"
          }
        ]
      }
    },
    {
      "name": "EnablePasswordlessExperience",
      "path": "./Device/Vendor/MSFT/Policy/Config/Authentication/EnablePasswordlessExperience",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Specifies whether connected users on AADJ devices receive a Passwordless experience on Windows",
      "default": "0",
      "applicability": {
        "minOsBuild": "10.0.22631.2506",
        "cspVersion": "11.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "The feature defaults to the existing edition and device capabilities."
          },
          {
            "value": "1",
            "description": "Enabled. The Passwordless experience will be enabled on Windows"
          },
          {
            "value": "2",
            "description": "Disabled. The Passwordless experience will not be enabled on Windows"
          }
        ]
      }
    },
    {
      "name": "EnableWebSignIn",
      "path": "./Device/Vendor/MSFT/Policy/Config/Authentication/EnableWebSignIn",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Specifies whether web-based sign-in is allowed for signing in to Windows",
      "default": "0",
      "applicability": {
        "minOsBuild": "10.0.17763",
        "cspVersion": "8.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "The feature defaults to the existing SKU and device capabilities."
          },
          {
            "value": "1",
            "description": "Enabled. Web Sign-in will be enabled for signing in to Windows"
          },
          {
            "value": "2",
            "description": "Disabled. Web Sign-in will not be enabled for signing in to Windows"
          }
        ]
      }
