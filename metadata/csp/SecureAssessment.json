      "format": "int",
      "access": [
        "Get",
        "Replace"
      ],
      "description": "Indicates if keyboard text suggestions are allowed by the app.",
      "default": "0",
      "applicability": {},
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "1",
            "description": "Keyboard text suggestions are allowed"
          },
          {
            "value": "0",
            "description": "Keyboard text suggestions are not allowed"
          }
        ]
      }
    },
    {
