    {
      "name": "AllowCortanaAboveLock",
      "path": "./Device/Vendor/MSFT/Policy/Config/AboveLock/AllowCortanaAboveLock",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Specifies whether or not the user can interact with Cortana using speech while the system is locked. If you enable or don’t configure this setting, the user can interact with Cortana using speech while the system is locked. If you disable this setting, the system will need to be unlocked for the user to interact with Cortana using speech.",
      "default": "1",
      "applicability": {
        "minOsBuild": "10.0.14393",
        "cspVersion": "4.1",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "Not allowed."
          },
          {
            "value": "1",
            "description": "Allowed."
          }
        ]
      }
    },
    {
      "name": "AllowToasts",
      "path": "./Device/Vendor/MSFT/Policy/Config/AboveLock/AllowToasts",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Specifies whether to allow toast notifications above the device lock screen. Most restricted value is 0.",
      "default": "1",
      "applicability": {
        "minOsBuild": "10.0.14393",
        "cspVersion": "4.1",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "Not allowed."
          },
          {
            "value": "1",
            "description": "Allowed."
          }
        ]
      }
    },
    {
      "name": "ConfigureAudioOnLockScreen",
      "path": "./Device/Vendor/MSFT/Policy/Config/AboveLock/ConfigureAudioOnLockScreen",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "This policy will allow the audio above lock screen to be managed by IT admins and allow apps like digital signage to play audio above lock screen without having a user signed on.",
      "default": "0",
      "applicability": {
        "minOsBuild": "99.9.99999",
        "cspVersion": "9.9",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "No audio playback or recording on lock screen (aside from OS defined exceptions)."
          },
          {
            "value": "1",
            "description": "Audio playback allowed on lock screen. Audio recording is not allowed."
          },
          {
            "value": "2",
            "description": "Audio playback and recording allowed on lock screen."
          }
        ]
      }
    }
