{
  "name": "TaskManager",
  "path": "./Device/Vendor/MSFT/Policy/Config",
  "nodes": [
    {
      "name": "AllowEndTask",
      "path": "./Device/Vendor/MSFT/Policy/Config/TaskManager/AllowEndTask",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "This setting determines whether non-administrators can use Task Manager to end tasks - enabled (1) or disabled (0). Default: enabled",
      "default": "1",
      "applicability": {
        "minOsBuild": "10.0.17763",
        "cspVersion": "8.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "Disabled. EndTask functionality is blocked in TaskManager."
          },
          {
            "value": "1",
            "description": "Enabled. Users can perform EndTask in TaskManager."
          }
        ]
      }
    }
  ]
}
