  "nodes": [
    {
      "name": "AllNetworks_NetworkIcon",
      "path": "./Device/Vendor/MSFT/Policy/Config/NetworkListManager/AllNetworks_NetworkIcon",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "This policy setting allows you to specify whether users can change the network icon for all networks to which the user connects.",
      "default": "0",
      "applicability": {
        "minOsBuild": "10.0.26100, 10.0.22621.5126",
        "cspVersion": "11.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCD;0xCF;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "User can change icon"
          },
          {
            "value": "1",
            "description": "User cannot change icon"
          }
        ]
      }
    },
