{
  "name": "Multitasking",
  "path": "./User/Vendor/MSFT/Policy/Config",
  "nodes": [
    {
      "name": "BrowserAltTabBlowout",
      "path": "./User/Vendor/MSFT/Policy/Config/Multitasking/BrowserAltTabBlowout",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Configures the inclusion of Microsoft Edge tabs into Alt-Tab.",
      "default": "1",
      "applicability": {
        "minOsBuild": "10.0.22000",
        "cspVersion": "11.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "1",
            "description": "Open windows and all tabs in Microsoft Edge"
          },
          {
            "value": "2",
            "description": "Open windows and 5 most recent tabs in Microsoft Edge"
          },
          {
            "value": "3",
            "description": "Open windows and 3 most recent tabs in Microsoft Edge"
          },
          {
            "value": "4",
            "description": "Open windows only"
          }
        ]
      }
    }
  ]
}
