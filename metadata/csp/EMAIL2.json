          "allowedValues": {
            "type": "ENUM",
            "enum": [
              {
                "value": "-1",
                "description": "No limit is enforced"
              },
              {
                "value": "0",
                "description": "No attachment is downloaded"
              },
              {
                "value": "25",
                "description": "25 KB"
              },
              {
                "value": "50",
                "description": "50 KB"
              },
              {
                "value": "100",
                "description": "100 KB"
              },
              {
                "value": "250",
                "description": "250 KB"
              }
