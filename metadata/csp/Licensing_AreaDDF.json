{
  "name": "Licensing",
  "path": "./Device/Vendor/MSFT/Policy/Config",
  "nodes": [
    {
      "name": "AllowWindowsEntitlementReactivation",
      "path": "./Device/Vendor/MSFT/Policy/Config/Licensing/AllowWindowsEntitlementReactivation",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Enables or Disable Windows license reactivation on managed devices.",
      "default": "1",
      "applicability": {
        "minOsBuild": "10.0.14393",
        "cspVersion": "4.1",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "Disable Windows license reactivation on managed devices."
          },
          {
            "value": "1",
            "description": "Enable Windows license reactivation on managed devices."
          }
        ]
      }
    },
    {
      "name": "DisallowKMSClientOnlineAVSValidation",
      "path": "./Device/Vendor/MSFT/Policy/Config/Licensing/DisallowKMSClientOnlineAVSValidation",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Enabling this setting prevents this computer from sending data to Microsoft regarding its activation state.",
      "default": "0",
      "applicability": {
        "minOsBuild": "10.0.14393",
        "cspVersion": "4.1",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "Disabled."
          },
          {
            "value": "1",
            "description": "Enabled."
          }
        ]
      }
    },
    {
      "name": "EnableESUSubscriptionCheck",
      "path": "./Device/Vendor/MSFT/Policy/Config/Licensing/EnableESUSubscriptionCheck",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "This policy will only work on Windows 10. Setting this policy will have no effect for other supported versions of Windows. This policy enables or disables subscription check for Windows 10 Extended Security Updates. If enabled, the device will check for ESU subscription status of the signed-in Microsoft Entra ID user account.",
      "default": "0",
      "applicability": {
        "minOsBuild": "99.9.99999, 10.0.19045.6387",
        "cspVersion": "4.1",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "Disabled."
          },
          {
            "value": "1",
            "description": "Enabled."
          }
        ]
      }
    }
