    {
      "name": "AuditInsecureGuestLogon",
      "path": "./Device/Vendor/MSFT/Policy/Config/LanmanServer/AuditInsecureGuestLogon",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "This policy controls whether the SMB server will enable the audit event when the client is logged on as guest account. If you enable this policy setting, the SMB server will log the event when the client is logged on as guest account. If you disable or do not configure this policy setting, the SMB server will not log the event.",
      "default": "0",
      "applicability": {
        "minOsBuild": "99.9.99999, 10.0.26100.3613",
        "cspVersion": "11.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;"
