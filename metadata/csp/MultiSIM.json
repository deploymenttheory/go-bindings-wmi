{
  "name": "MultiSIM",
  "path": "./Device/Vendor/MSFT",
  "nodes": [
    {
      "name": "",
      "path": "./Device/Vendor/MSFT/MultiSIM/",
      "format": "node",
      "access": [
        "Get"
      ],
      "description": "Node representing a Mobile Broadband Modem. The node name is the Modem ID. Modem ID is a GUID without curly braces, with exception of \"Embedded\" which represents the embedded Modem.",
      "applicability": {},
      "children": [
        {
          "name": "Identifier",
          "path": "./Device/Vendor/MSFT/MultiSIM/Identifier",
          "format": "chr",
          "access": [
            "Get"
          ],
          "description": "Modem ID.",
          "applicability": {}
        },
        {
          "name": "IsEmbedded",
          "path": "./Device/Vendor/MSFT/MultiSIM/IsEmbedded",
          "format": "bool",
          "access": [
            "Get"
          ],
          "description": "Indicates whether this Modem is embedded or external.",
          "applicability": {}
        },
        {
          "name": "Policies",
          "path": "./Device/Vendor/MSFT/MultiSIM/Policies",
          "format": "node",
          "access": [
            "Get"
          ],
          "description": "Policies associated with the Modem.",
          "applicability": {},
          "children": [
            {
              "name": "SlotSelectionEnabled",
              "path": "./Device/Vendor/MSFT/MultiSIM/Policies/SlotSelectionEnabled",
              "format": "bool",
              "access": [
                "Get",
                "Replace"
              ],
              "description": "Determines whether the user is allowed to change slots in the Cellular settings UI. Default is true.",
              "default": "true",
              "applicability": {},
              "allowedValues": {
                "type": "ENUM",
                "enum": [
                  {
                    "value": "false",
                    "description": "Disabled"
                  },
                  {
                    "value": "true",
                    "description": "Enabled"
                  }
                ]
              }
            }
          ]
        },
        {
          "name": "Slots",
          "path": "./Device/Vendor/MSFT/MultiSIM/Slots",
          "format": "node",
          "access": [
            "Get"
          ],
          "description": "Represents all SIM slots in the Modem.",
          "applicability": {},
          "children": [
            {
              "name": "",
              "path": "./Device/Vendor/MSFT/MultiSIM/Slots/",
              "format": "node",
              "access": [
                "Get"
              ],
              "description": "Node representing a SIM Slot. The node name is the Slot ID. SIM Slot ID format is \"0\", \"1\", etc., with exception of \"Embedded\" which represents the embedded Slot.",
              "applicability": {},
              "children": [
                {
                  "name": "Identifier",
                  "path": "./Device/Vendor/MSFT/MultiSIM/Slots/Identifier",
                  "format": "int",
                  "access": [
                    "Get"
                  ],
                  "description": "Slot ID.",
                  "applicability": {}
                },
                {
                  "name": "IsEmbedded",
                  "path": "./Device/Vendor/MSFT/MultiSIM/Slots/IsEmbedded",
                  "format": "bool",
                  "access": [
                    "Get"
                  ],
                  "description": "Indicates whether this Slot is embedded or a physical SIM slot.",
                  "applicability": {}
                },
                {
                  "name": "IsSelected",
                  "path": "./Device/Vendor/MSFT/MultiSIM/Slots/IsSelected",
                  "format": "bool",
                  "access": [
                    "Get",
                    "Replace"
                  ],
                  "description": "Indicates whether this Slot is selected or not.",
                  "applicability": {},
                  "allowedValues": {
                    "type": "ENUM",
                    "enum": [
                      {
                        "value": "false",
                        "description": "Not selected"
                      },
                      {
                        "value": "true",
                        "description": "Selected"
                      }
                    ]
                  }
                },
                {
                  "name": "State",
                  "path": "./Device/Vendor/MSFT/MultiSIM/Slots/State",
                  "format": "int",
                  "access": [
                    "Get"
                  ],
                  "description": "Slot state (Unknown = 0, OffEmpty = 1, Off = 2, Empty = 3, NotReady = 4, Active = 5, Error = 6, ActiveEsim = 7, ActiveEsimNoProfile = 8)",
                  "applicability": {}
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
