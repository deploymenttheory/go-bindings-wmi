{
  "name": "WiFi",
  "path": "./Device/Vendor/MSFT",
  "nodes": [
    {
      "name": "Profile",
      "path": "./Device/Vendor/MSFT/WiFi/Profile",
      "format": "node",
      "access": [
        "Get"
      ],
      "description": "Identifies the Wi-Fi network configuration. Each Wi-Fi network configuration is represented by a profile object. This network profile includes all the information required for the device to connect to that network, including SSID and security configuration (such as passphrase for WPA2-Personal networks).",
      "applicability": {},
      "children": [
        {
          "name": "",
          "path": "./Device/Vendor/MSFT/WiFi/Profile/",
          "format": "node",
          "access": [
            "Add",
            "Delete",
            "Get",
            "Replace"
          ],
          "description": "The Profile name of the Wi-Fi network. This is added when WlanXml node is added and deleted when WlanXml is deleted. This must match the 'name' in the 'WLANProfile' contained in the WlanXml node.",
          "applicability": {},
          "children": [
            {
              "name": "ProfileSource",
              "path": "./Device/Vendor/MSFT/WiFi/Profile/ProfileSource",
              "format": "int",
              "access": [
                "Get",
                "Replace"
              ],
              "description": "Allows for defining which administrative entity is setting this Wi-Fi profile. This can currently be set to either 0=Enterprise or 1=Mobile Operator.",
              "default": "0",
              "applicability": {
                "minOsBuild": "10.0.22621",
                "cspVersion": "1.1"
              },
              "allowedValues": {
                "type": "ENUM",
                "enum": [
                  {
                    "value": "0",
                    "description": "Enterprise"
                  },
                  {
                    "value": "1",
                    "description": "Mobile Operator"
                  }
                ]
              }
            },
            {
              "name": "Proxy",
              "path": "./Device/Vendor/MSFT/WiFi/Profile/Proxy",
              "format": "chr",
              "access": [
                "Add",
                "Delete",
                "Get",
                "Replace"
              ],
              "description": "Optional node. The format is url:port. Configuration of the network proxy (if any).",
              "applicability": {},
              "allowedValues": {
                "type": "None"
              }
            },
            {
              "name": "ProxyPacUrl",
              "path": "./Device/Vendor/MSFT/WiFi/Profile/ProxyPacUrl",
              "format": "chr",
              "access": [
                "Add",
                "Delete",
                "Get",
                "Replace"
              ],
              "description": "Optional node. URL to the PAC file location.",
              "applicability": {
                "minOsBuild": "10.0.22000, 10.0.14393",
                "cspVersion": "1.1"
              },
              "allowedValues": {
                "type": "None"
              }
            },
            {
              "name": "ProxyWPAD",
              "path": "./Device/Vendor/MSFT/WiFi/Profile/ProxyWPAD",
              "format": "bool",
              "access": [
                "Add",
                "Delete",
                "Get",
                "Replace"
              ],
              "description": "Optional node. The presence of the field enables WPAD for proxy lookup.",
              "applicability": {
                "minOsBuild": "10.0.22000, 10.0.14393",
                "cspVersion": "1.1"
              },
              "allowedValues": {
                "type": "ENUM",
                "enum": [
                  {
                    "value": "false",
                    "description": "Disable WPAD for proxy lookup."
                  },
                  {
                    "value": "true",
                    "description": "Enable WPAD for proxy lookup."
                  }
                ]
              }
            },
            {
              "name": "WiFiCost",
              "path": "./Device/Vendor/MSFT/WiFi/Profile/WiFiCost",
              "format": "int",
              "access": [
                "Add",
                "Delete",
                "Get",
                "Replace"
              ],
              "description": "Optional node. If the policy is active selecting one of the values from the following list will set the cost of WLAN connection for the Wi-Fi profile. (1:Unrestricted - unlimited connection, 2: Fixed - capacity constraints up to a certain data limit, 3: Variable - costed on per byte basic) Default behaviour: Unrestricted",
              "default": "1",
              "applicability": {
                "minOsBuild": "10.0.22000, 10.0.17763",
                "cspVersion": "1.1"
              },
              "allowedValues": {
                "type": "ENUM",
                "enum": [
                  {
                    "value": "1",
                    "description": "Unrestricted - unlimited connection."
                  },
                  {
                    "value": "2",
                    "description": "Fixed - capacity constraints up to a certain data limit."
                  },
                  {
                    "value": "3",
                    "description": "Variable - paid on per byte basic."
                  }
                ]
              }
            },
            {
              "name": "WlanXml",
              "path": "./Device/Vendor/MSFT/WiFi/Profile/WlanXml",
              "format": "chr",
              "access": [
                "Add",
                "Delete",
                "Get",
                "Replace"
              ],
              "description": "XML describing the network configuration and follows Windows WLAN_profile schema.\n              Link to schema: http://msdn.microsoft.com/en-us/library/windows/desktop/ms707341(v=vs.85).aspx",
              "applicability": {}
            }
          ]
        }
      ]
    },
