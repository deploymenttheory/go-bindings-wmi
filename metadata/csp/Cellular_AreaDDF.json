      "path": "./Device/Vendor/MSFT/Policy/Config/Cellular/LetAppsAccessCellularData",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "This policy setting specifies whether Windows apps can access cellular data.",
      "default": "0",
      "applicability": {
        "minOsBuild": "10.0.16299",
        "cspVersion": "6.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;"
