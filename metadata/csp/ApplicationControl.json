{
  "name": "ApplicationControl",
  "path": "./Vendor/MSFT",
  "nodes": [
    {
      "name": "Policies",
      "path": "./Vendor/MSFT/ApplicationControl/Policies",
      "format": "node",
      "access": [
        "Get"
      ],
      "description": "Beginning of a Subtree that contains all policies.",
      "applicability": {},
      "children": [
        {
          "name": "",
          "path": "./Vendor/MSFT/ApplicationControl/Policies/",
          "format": "node",
          "access": [
            "Get"
          ],
          "description": "The GUID of the Policy",
          "applicability": {},
          "children": [
            {
              "name": "Policy",
              "path": "./Vendor/MSFT/ApplicationControl/Policies/Policy",
              "format": "b64",
              "access": [
                "Add",
                "Delete",
                "Get",
                "Replace"
              ],
              "description": "The policy binary encoded as base64. Supported value is a binary file, converted from the policy XML file by the ConvertFrom-CIPolicy cmdlet.",
              "applicability": {},
              "allowedValues": {
                "type": "None"
              }
            },
            {
              "name": "PolicyInfo",
              "path": "./Vendor/MSFT/ApplicationControl/Policies/PolicyInfo",
              "format": "node",
              "access": [
                "Get"
              ],
              "description": "Information Describing the Policy indicated by the GUID",
              "applicability": {},
              "children": [
                {
                  "name": "BasePolicyId",
                  "path": "./Vendor/MSFT/ApplicationControl/Policies/PolicyInfo/BasePolicyId",
                  "format": "chr",
                  "access": [
                    "Get"
                  ],
                  "description": "The BasePolicyId of the Policy Indicated by the Policy GUID",
                  "applicability": {}
                },
                {
                  "name": "FriendlyName",
                  "path": "./Vendor/MSFT/ApplicationControl/Policies/PolicyInfo/FriendlyName",
                  "format": "chr",
                  "access": [
                    "Get"
                  ],
                  "description": "The FriendlyName of the Policy Indicated by the Policy GUID",
                  "applicability": {}
                },
                {
                  "name": "IsAuthorized",
                  "path": "./Vendor/MSFT/ApplicationControl/Policies/PolicyInfo/IsAuthorized",
                  "format": "bool",
                  "access": [
                    "Get"
                  ],
                  "description": "Whether the Policy indicated by the GUID is authorized to be loaded by the enforcement engine on the system",
                  "applicability": {}
                },
                {
                  "name": "IsBasePolicy",
                  "path": "./Vendor/MSFT/ApplicationControl/Policies/PolicyInfo/IsBasePolicy",
                  "format": "bool",
                  "access": [
                    "Get"
                  ],
                  "description": "TRUE/FALSE if the Policy is a Base Policy versus a Supplemental Policy",
                  "applicability": {}
                },
                {
                  "name": "IsDeployed",
                  "path": "./Vendor/MSFT/ApplicationControl/Policies/PolicyInfo/IsDeployed",
                  "format": "bool",
                  "access": [
                    "Get"
                  ],
                  "description": "Whether the Policy indicated by the GUID is deployed on the system (on the physical machine)",
                  "applicability": {}
                },
                {
                  "name": "IsEffective",
                  "path": "./Vendor/MSFT/ApplicationControl/Policies/PolicyInfo/IsEffective",
                  "format": "bool",
                  "access": [
                    "Get"
                  ],
                  "description": "Whether the Policy indicated by the GUID is Effective on the system (loaded by the enforcement engine and in effect)",
                  "applicability": {}
                },
                {
                  "name": "IsSystemPolicy",
                  "path": "./Vendor/MSFT/ApplicationControl/Policies/PolicyInfo/IsSystemPolicy",
                  "format": "bool",
                  "access": [
                    "Get"
                  ],
                  "description": "TRUE/FALSE if the Policy is a System Policy, that is a policy managed by Microsoft as part of the OS",
                  "applicability": {}
                },
                {
                  "name": "PolicyOptions",
                  "path": "./Vendor/MSFT/ApplicationControl/Policies/PolicyInfo/PolicyOptions",
                  "format": "chr",
                  "access": [
                    "Get"
                  ],
                  "description": "The PolicyOptions of the Policy Indicated by the Policy GUID",
                  "applicability": {}
                },
                {
                  "name": "Status",
                  "path": "./Vendor/MSFT/ApplicationControl/Policies/PolicyInfo/Status",
                  "format": "int",
                  "access": [
                    "Get"
                  ],
                  "description": "The Current Status of the Policy Indicated by the Policy GUID",
                  "applicability": {}
                },
                {
                  "name": "Version",
                  "path": "./Vendor/MSFT/ApplicationControl/Policies/PolicyInfo/Version",
                  "format": "chr",
                  "access": [
                    "Get"
                  ],
                  "description": "Version of the Policy indicated by the GUID, as a string. When parsing use a uint64 as the containing data type",
                  "applicability": {}
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "Tokens",
      "path": "./Vendor/MSFT/ApplicationControl/Tokens",
      "format": "node",
      "access": [
        "Get"
      ],
      "description": "Beginning of a Subtree that contains all tokens.",
      "applicability": {},
      "children": [
        {
          "name": "",
          "path": "./Vendor/MSFT/ApplicationControl/Tokens/",
          "format": "node",
          "access": [
            "Get"
          ],
          "description": "Arbitrary ID used to differentiate tokens",
          "applicability": {},
          "children": [
            {
              "name": "Token",
              "path": "./Vendor/MSFT/ApplicationControl/Tokens/Token",
              "format": "b64",
              "access": [
                "Add",
                "Delete",
                "Get",
                "Replace"
              ],
              "description": "The token binary encoded as base64. Supported value is a binary file, obtained from the OneCoreDeviceUnlockService.",
              "applicability": {},
              "allowedValues": {
                "type": "None"
              }
            },
            {
              "name": "TokenInfo",
              "path": "./Vendor/MSFT/ApplicationControl/Tokens/TokenInfo",
              "format": "node",
              "access": [
                "Get"
              ],
              "description": "Information Describing the Token indicated by the corresponding ID.",
              "applicability": {},
              "children": [
                {
                  "name": "Status",
                  "path": "./Vendor/MSFT/ApplicationControl/Tokens/TokenInfo/Status",
                  "format": "int",
                  "access": [
                    "Get"
                  ],
                  "description": "The Current Status of the Token Indicated by the Token ID",
                  "applicability": {}
                },
                {
                  "name": "Type",
                  "path": "./Vendor/MSFT/ApplicationControl/Tokens/TokenInfo/Type",
                  "format": "int",
                  "access": [
                    "Get"
                  ],
                  "description": "The Type of Token Indicated by the Token ID",
                  "applicability": {}
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
