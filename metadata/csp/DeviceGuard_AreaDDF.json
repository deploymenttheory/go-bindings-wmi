{
  "name": "DeviceGuard",
  "path": "./Device/Vendor/MSFT/Policy/Config",
  "nodes": [
    {
      "name": "ConfigureSystemGuardLaunch",
      "path": "./Device/Vendor/MSFT/Policy/Config/DeviceGuard/ConfigureSystemGuardLaunch",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Secure Launch configuration: 0 - Unmanaged, configurable by Administrative user, 1 - Enables Secure Launch if supported by hardware, 2 - Disables Secure Launch.",
      "default": "0",
      "applicability": {
        "minOsBuild": "10.0.17763",
        "cspVersion": "8.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x62;0x63;0x64;0x65;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCA;0xCB;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "Unmanaged Configurable by Administrative user"
          },
          {
            "value": "1",
            "description": "Unmanaged Enables Secure Launch if supported by hardware"
          },
          {
            "value": "2",
            "description": "Unmanaged Disables Secure Launch"
          }
        ]
      }
    },
    {
      "name": "EnableVirtualizationBasedSecurity",
      "path": "./Device/Vendor/MSFT/Policy/Config/DeviceGuard/EnableVirtualizationBasedSecurity",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Turns On Virtualization Based Security(VBS)",
      "default": "0",
      "applicability": {
        "minOsBuild": "10.0.16299",
        "cspVersion": "6.0",
        "editions": "0x4;0x1B;0x30;0x31;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0x8A;0x8B;0xA1;0xA2;0xA4;0xA5;0xAB;0xAC;0xAF;0xBC;0xBF;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "disable virtualization based security."
          },
          {
            "value": "1",
            "description": "enable virtualization based security."
          }
        ]
      }
    },
    {
      "name": "LsaCfgFlags",
      "path": "./Device/Vendor/MSFT/Policy/Config/DeviceGuard/LsaCfgFlags",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Credential Guard Configuration: 0 - Turns off CredentialGuard remotely if configured previously without UEFI Lock, 1 - Turns on CredentialGuard with UEFI lock. 2 - Turns on CredentialGuard without UEFI lock.",
      "default": "0",
      "applicability": {
        "minOsBuild": "10.0.16299",
        "cspVersion": "6.0",
        "editions": "0x4;0x1B;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0xAB;0xAC;0xAF;0xBC;0xBF;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "(Disabled) Turns off Credential Guard remotely if configured previously without UEFI Lock."
          },
          {
            "value": "1",
            "description": "(Enabled with UEFI lock) Turns on Credential Guard with UEFI lock."
          },
          {
            "value": "2",
            "description": "(Enabled without lock) Turns on Credential Guard without UEFI lock."
          }
        ]
      }
    },
    {
      "name": "MachineIdentityIsolation",
      "path": "./Device/Vendor/MSFT/Policy/Config/DeviceGuard/MachineIdentityIsolation",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Machine Identity Isolation: 0 - Machine password is only LSASS-bound and stored in $MACHINE.ACC registry key. 1 - Machine password both LSASS-bound and IUM-bound. It is stored in $MACHINE.ACC and $MACHINE.ACC.IUM registry keys. 2 - Machine password is only IUM-bound and stored in $MACHINE.ACC.IUM registry key.",
      "default": "0",
      "applicability": {
        "minOsBuild": "99.9.99999",
        "cspVersion": "9.9",
        "editions": "0x4;0x1B;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0xAB;0xAC;0xAF;0xBC;0xBF;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "0",
            "description": "(Disabled) Machine password is only LSASS-bound and stored in $MACHINE.ACC registry key."
          },
          {
            "value": "1",
            "description": "(Enabled in audit mode) Machine password both LSASS-bound and IUM-bound. It is stored in $MACHINE.ACC and $MACHINE.ACC.IUM registry keys."
          },
          {
            "value": "2",
            "description": "(Enabled in enforcement mode) Machine password is only IUM-bound and stored in $MACHINE.ACC.IUM registry key."
          }
        ]
      }
    },
    {
      "name": "RequireMicrosoftSignedBootChain",
      "path": "./Device/Vendor/MSFT/Policy/Config/DeviceGuard/RequireMicrosoftSignedBootChain",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Require Microsoft Signed Boot Chain: 1 - Require Microsoft Signed Boot Chain.",
      "default": "1",
      "applicability": {
        "minOsBuild": "99.9.99999",
        "cspVersion": "9.9",
        "editions": "0x4;0x1B;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0xAB;0xAC;0xAF;0xBC;0xBF;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "1",
            "description": "Require Microsoft Signed Boot Chain."
          }
        ]
      }
    },
    {
      "name": "RequirePlatformSecurityFeatures",
      "path": "./Device/Vendor/MSFT/Policy/Config/DeviceGuard/RequirePlatformSecurityFeatures",
      "format": "int",
      "access": [
        "Add",
        "Delete",
        "Get",
        "Replace"
      ],
      "description": "Select Platform Security Level: 1 - Turns on VBS with Secure Boot, 3 - Turns on VBS with Secure Boot and DMA. DMA requires hardware support.",
      "default": "1",
      "applicability": {
        "minOsBuild": "10.0.16299",
        "cspVersion": "6.0",
        "editions": "0x4;0x1B;0x48;0x54;0x79;0x7A;0x7D;0x7E;0x81;0x82;0xAB;0xAC;0xAF;0xBC;0xBF;0xCD;0xCF;0xD2;"
      },
      "allowedValues": {
        "type": "ENUM",
        "enum": [
          {
            "value": "1",
            "description": "Turns on VBS with Secure Boot."
          },
          {
            "value": "3",
            "description": "Turns on VBS with Secure Boot and direct memory access (DMA). DMA requires hardware support."
          }
        ]
      }
    }
  ]
}
