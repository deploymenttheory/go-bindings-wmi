# Normalize line endings so the repository is byte-identical across OSes.
# Text is stored as LF; binaries are left untouched.
* text=auto

*.go   text eol=lf
*.mod  text eol=lf
*.sum  text eol=lf
*.tmpl text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Generator golden files are compared byte-for-byte against LF output.
*.golden text eol=lf

*.winmd binary
